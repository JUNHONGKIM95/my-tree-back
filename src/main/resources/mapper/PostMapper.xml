<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mytree.repository.PostRepository">

	<resultMap id="postResultMap" type="com.example.mytree.domain.Post">
		<id property="postNo" column="post_no"/>
		<result property="userId" column="user_id"/>
		<result property="title" column="title"/>
		<result property="content" column="content"/>
		<result property="createdAt" column="created_at"/>
	</resultMap>

	<insert id="insert" parameterType="com.example.mytree.domain.Post">
		<selectKey keyProperty="postNo" order="BEFORE" resultType="long">
			SELECT SEQ_POST_NO.NEXTVAL FROM dual
		</selectKey>
		INSERT INTO posts (
			post_no,
			user_id,
			title,
			content,
			created_at
		) VALUES (
			#{postNo},
			#{userId},
			#{title},
			#{content},
			#{createdAt}
		)
	</insert>

	<select id="findByPostNo" resultMap="postResultMap">
		SELECT
			post_no,
			user_id,
			title,
			content,
			created_at
		FROM posts
		WHERE post_no = #{postNo}
	</select>

	<select id="findAll" resultMap="postResultMap">
		SELECT
			post_no,
			user_id,
			title,
			content,
			created_at
		FROM posts
		ORDER BY created_at DESC, post_no DESC
	</select>

	<delete id="deleteByPostNo">
		DELETE FROM posts
		WHERE post_no = #{postNo}
	</delete>

	<delete id="deleteAll">
		DELETE FROM posts
	</delete>
</mapper>
